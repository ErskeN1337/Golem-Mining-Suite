<UserControl x:Class="Golem_Mining_Suite.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Golem_Mining_Suite.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">
            <!-- Header -->
            <TextBlock Text="Settings" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,30"/>

            <!-- General Settings -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="25"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="General" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,15"/>
                    
                    <!-- Always on Top -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Always on Top" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Keep the window floating above other applications (useful for gaming)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,5,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding AlwaysOnTop}" VerticalAlignment="Center" LayoutTransform="{DynamicResource Scale1.5}">
                            <CheckBox.Resources>
                                <ScaleTransform x:Key="Scale1.5" ScaleX="1.5" ScaleY="1.5"/>
                            </CheckBox.Resources>
                        </CheckBox>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,15" Opacity="0.5"/>

                    <!-- Window Opacity -->
                    <Grid Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Window Opacity" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Adjust transparency to see the game behind the app" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding WindowOpacity, StringFormat=P0}" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Margin="10,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Slider Grid.Row="1" Minimum="0.2" Maximum="1.0" Value="{Binding WindowOpacity}" LargeChange="0.1" SmallChange="0.05" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,15" Opacity="0.5"/>

                    <!-- Theme Accent -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="App Theme" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Choose your preferred accent color" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,5,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" DisplayMemberPath="Name"  Width="200" Height="35" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,15" Opacity="0.5"/>

                    <!-- Wave 8A: Discord Account. Only shown when DI wired a DiscordAuthService. -->
                    <StackPanel Visibility="{Binding IsDiscordAvailable, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Discord Account" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Sign in to auto-populate your Star Citizen Handle and (soon) sync scouting finds."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,5,0,10" TextWrapping="Wrap"/>

                        <!-- Signed-out state: big blurple button. -->
                        <Button Command="{Binding SignInCommand}"
                                Visibility="{Binding IsDiscordSignedOut, Converter={StaticResource BoolToVis}}"
                                Height="40"
                                Width="220"
                                HorizontalAlignment="Left"
                                Background="#5865F2"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSigningIn}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sign in with Discord" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Signed-in state: avatar + username + sign-out link. -->
                        <Grid Visibility="{Binding IsDiscordSignedIn, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar (hidden when no hash — string.Empty URL image source fails silently). -->
                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" ClipToBounds="True"
                                    Background="{DynamicResource PrimaryBackgroundBrush}" Margin="0,0,12,0">
                                <Image Source="{Binding DiscordAvatarUrl}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DiscordUsername}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Signed in with Discord"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Sign-out as a link-style button so it reads as a soft secondary action. -->
                            <Button Grid.Column="2"
                                    Content="Sign out"
                                    Command="{Binding SignOutCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource AccentBrush}"
                                    FontSize="13"
                                    Cursor="Hand"
                                    Padding="8,4"/>
                        </Grid>
                    </StackPanel>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,15,0,15" Opacity="0.5"
                               Visibility="{Binding IsDiscordAvailable, Converter={StaticResource BoolToVis}}"/>

                    <!-- Star Citizen Handle (used by Crew Sessions / My Share). Becomes read-only when Discord owns it. -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Star Citizen Handle" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Your in-game name (scName). Used to compute your share of crew mining sessions." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBox Grid.Column="1"
                                 Text="{Binding UserHandle, UpdateSourceTrigger=LostFocus}"
                                 IsReadOnly="{Binding IsDiscordSignedIn}"
                                 Width="200"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 Background="{DynamicResource PrimaryBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 CaretBrush="{DynamicResource AccentBrush}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDiscordSignedIn}" Value="True">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Live Data Section (Placeholder) -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="25"
                    Opacity="0.7">
                <StackPanel>
                     <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🌐 Live Crowdsourced Data" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Border Background="#333333" CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="COMING SOON" FontSize="11" FontWeight="Bold" Foreground="#FFC107"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Community-shared prices functionality is currently in development." Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
